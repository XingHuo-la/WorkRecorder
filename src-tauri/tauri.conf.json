{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkRecorder",
  "version": "1.0.4",
  "identifier": "com.a1633.WorkRecorder",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "work_recorder",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "window-controls",
          "windows": ["*"],
          "permissions": [
            "core:window:allow-close",
            "core:window:allow-minimize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-start-dragging"
          ]
        },
        {
          "identifier": "dialog-controls",
          "windows": ["*"],
          "permissions": [
            "dialog:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "dialog:allow-confirm"
          ]
        },
        {
          "identifier": "updater-controls",
          "windows": ["*"],
          "permissions": [
            "updater:default",
            "updater:allow-check",
            "updater:allow-download-and-install",
            "process:default",
            "process:allow-restart"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/XingHuo-la/WorkRecorder/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGOTNENjI5NjhGMzdCREMKUldUY2UvTm9LZGFUSHdQQ1FqamxCQisycWFETzQ4N0xIcXhFenFNamZTRllvbGFhSkxnNWtXTVMK"
    }
  }
}